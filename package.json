{
  "name": "flexily",
  "version": "0.3.0",
  "description": "Pure JavaScript flexbox layout engine — Yoga-compatible API, faster initial layout, smaller bundle, no WASM",
  "keywords": [
    "canvas-ui",
    "css",
    "flexbox",
    "layout",
    "measure",
    "pure-javascript",
    "terminal",
    "tui",
    "ui-layout",
    "yoga",
    "yoga-alternative",
    "yoga-wasm",
    "zero-dependency"
  ],
  "homepage": "https://beorn.github.io/flexily/",
  "bugs": {
    "url": "https://github.com/beorn/flexily/issues"
  },
  "license": "MIT",
  "author": "beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/flexily.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./classic": {
      "types": "./src/classic/index.ts",
      "import": "./src/classic/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "bench": "bunx --bun vitest bench",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.1.0",
    "yoga-wasm-web": "^0.3.3"
  }
}
