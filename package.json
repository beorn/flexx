{
  "name": "flexily",
  "version": "0.2.0",
  "description": "Pure JavaScript flexbox layout engine — Yoga-compatible API, faster initial layout, smaller bundle, no WASM",
  "keywords": [
    "canvas-ui",
    "css",
    "flexbox",
    "layout",
    "measure",
    "pure-javascript",
    "terminal",
    "tui",
    "ui-layout",
    "yoga",
    "yoga-alternative",
    "yoga-wasm",
    "zero-dependency"
  ],
  "homepage": "https://beorn.github.io/flexily/",
  "bugs": {
    "url": "https://github.com/beorn/flexily/issues"
  },
  "license": "MIT",
  "author": "beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/flexily.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./classic": {
      "types": "./dist/index-classic.d.ts",
      "import": "./dist/index-classic.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "bench": "bunx --bun vitest bench",
    "bench:standalone": "bun bench/run.ts",
    "bench:compare": "bun bench/compare.ts",
    "typecheck": "tsc --noEmit",
    "build:docs": "cd docs && bun run docs:build",
    "ci": "bun run typecheck && bun test",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/debug": "^4.1.12",
    "loggily": "github:beorn/loggily",
    "typescript": "^5.7.3",
    "yoga-wasm-web": "^0.3.3"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18"
  }
}
